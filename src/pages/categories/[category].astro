---
import type { CollectionEntry } from "astro:content";
import PostList from "@/components/blog/PostList.astro";
import {
	getAllPosts,
	getCategorySlug,
	getPostsByCategory,
	getUniqueCategories,
	sortMDByDate,
} from "@/data/post";
import PageLayout from "@/layouts/Base.astro";
import { withBase } from "@/utils/path";
import type { GetStaticPaths } from "astro";

export const getStaticPaths = (async () => {
	const posts = sortMDByDate(await getAllPosts());
	return getUniqueCategories(posts).map((category) => ({
		params: { category: getCategorySlug(category) },
		props: { category, posts: getPostsByCategory(posts, category) },
	}));
}) satisfies GetStaticPaths;

interface Props {
	category: string;
	posts: CollectionEntry<"post">[];
}

const { posts, category } = Astro.props;
const count = posts.length;

const meta = {
	description: `Every post in ${category}.`,
	title: `${category} posts`,
};
---

<PageLayout meta={meta}>
	<section class="category-archive" aria-labelledby="category-label">
		<nav class="crumbs" aria-label="Breadcrumb">
			<a data-astro-prefetch href={withBase("/categories/")}>Categories</a>
			<span class="sep" aria-hidden="true">/</span>
			<span class="current" aria-current="page">{category}</span>
		</nav>
		<div class="section-label" id="category-label">
			{category} · {count} {count === 1 ? "post" : "posts"}
		</div>
		<div class="timeline">
			<PostList posts={posts} />
		</div>
	</section>
</PageLayout>

<style>
	.category-archive {
		margin-bottom: 96px;
	}

	.crumbs {
		font-family: var(--font-mono);
		font-size: 11.5px;
		letter-spacing: 0.04em;
		color: hsl(var(--theme-text) / 0.55);
		margin-bottom: 18px;
	}
	.crumbs a {
		color: hsl(var(--theme-text-muted));
		text-decoration: underline;
		text-decoration-color: hsl(var(--theme-text) / 0.35);
		text-decoration-thickness: 1px;
		text-underline-offset: 3px;
		transition: color 0.2s ease, text-decoration-color 0.2s ease;
	}
	.crumbs a:hover {
		color: hsl(var(--theme-accent));
		text-decoration-color: hsl(var(--theme-accent));
	}
	.crumbs a:focus-visible {
		outline: 2px solid hsl(var(--theme-accent));
		outline-offset: 3px;
		border-radius: 3px;
	}
	.crumbs .sep {
		color: var(--faint);
		margin: 0 8px;
	}

	@media (max-width: 420px) {
		.category-archive {
			margin-bottom: 64px;
		}
	}
</style>
